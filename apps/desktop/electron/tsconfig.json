{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "../dist-electron",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "declaration": false
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "../dist-electron", "*.test.ts"]
}

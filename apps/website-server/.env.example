# 官网后端环境变量
#
# apps/website-server 负责解析下载链接，并把官网桌面端/移动端下载点击上报到
# 飞书多维表格。官网前端通过 Vite 或 nginx 代理访问 /website-server/*。

# HTTP 监听地址和端口。Docker 部署时 HOST 通常保持 0.0.0.0，方便容器网络访问。
HOST=0.0.0.0
PORT=3207

# CORS 只在直接调用 website-server 接口时有意义；正常官网流量会通过
# /website-server 同源代理转发。
ALLOWED_ORIGIN=*

# 飞书 OpenAPI 地址，通常不用修改。
FEISHU_OPEN_API_BASE=https://open.feishu.cn/open-apis

# 飞书应用凭证。需要创建企业自建应用，开通多维表格读写权限，并把应用添加为
# 目标多维表格的可编辑协作者。
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 目标多维表格 app_token 和 table_id。下面四个飞书关键变量全部非空时，
# 下载上报才会启用；否则 website-server 只做下载跳转/解析。
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=

# 飞书多维表格字段名映射。如果你的表格列名不同，只改等号右侧即可。
#
# 必需字段类型：
# - 时间：日期时间字段
# - 平台：文本字段
# - 下载链接：URL 字段
# - 来源页面：URL 字段；请求没有合法 Referer 时会省略该字段
# - User Agent：文本字段
# - IP：文本字段
# - 客户端版本：文本字段；前端通过 ?version= 传入，缺省时省略该字段
FEISHU_DOWNLOAD_FIELD_TIME=时间
FEISHU_DOWNLOAD_FIELD_PLATFORM=平台
FEISHU_DOWNLOAD_FIELD_URL=下载链接
FEISHU_DOWNLOAD_FIELD_PAGE=来源页面
FEISHU_DOWNLOAD_FIELD_USER_AGENT=User Agent
FEISHU_DOWNLOAD_FIELD_IP=IP
FEISHU_DOWNLOAD_FIELD_VERSION=客户端版本

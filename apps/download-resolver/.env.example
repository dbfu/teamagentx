# download-resolver 服务监听地址
# Docker 部署通常保持 0.0.0.0，便于容器网络访问。
HOST=0.0.0.0

# download-resolver 服务监听端口
PORT=3207

# CORS 允许来源
# 官网通过同源 nginx/Vite 代理访问时不会依赖 CORS；如果需要直接调试接口，
# 可以设置成官网地址，例如 http://localhost:5184 或 https://teamagentx.example.com。
ALLOWED_ORIGIN=*

# 飞书 OpenAPI 地址，通常不用改。
FEISHU_OPEN_API_BASE=https://open.feishu.cn/open-apis

# 飞书多维表格下载统计
# 要做的事情：
# 1. 在飞书开放平台创建企业自建应用，拿到 App ID 和 App Secret。
# 2. 给应用开通多维表格读写权限，并把应用添加为目标多维表格的可编辑协作者。
# 3. 新建一个多维表格数据表，用于记录官网下载点击。
# 4. 从多维表格 URL 中复制 app_token 和 table_id，分别填到 FEISHU_BITABLE_APP_TOKEN / FEISHU_BITABLE_TABLE_ID。
# 5. 数据表至少创建以下字段，字段名必须和下面 FEISHU_DOWNLOAD_FIELD_* 配置一致：
#    时间、平台、下载链接、来源页面、User Agent、IP
# 6. 部署 download-resolver 后，官网点击 macOS / Windows / Android 下载会写入一条记录。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=

# 飞书多维表格字段名映射
# 如果你的表格列名不同，只改右侧字段名即可。
FEISHU_DOWNLOAD_FIELD_TIME=时间
FEISHU_DOWNLOAD_FIELD_PLATFORM=平台
FEISHU_DOWNLOAD_FIELD_URL=下载链接
FEISHU_DOWNLOAD_FIELD_PAGE=来源页面
FEISHU_DOWNLOAD_FIELD_USER_AGENT=User Agent
FEISHU_DOWNLOAD_FIELD_IP=IP

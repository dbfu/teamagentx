# 官网前端环境变量
#
# 这些变量供 apps/website 在 Vite 开发/构建时使用，也会被 Docker 入口脚本
# docker-entrypoint.sh 用来在容器启动时重新生成 update.json。
# 飞书多维表格凭证不要放在这里，应放到 apps/website-server/.env。

# 官网展示的应用版本号，也会写入 public/update.json。
VITE_APP_VERSION=v1.2.0

# 桌面端下载链接。
VITE_DOWNLOAD_URL_MAC_ARM64=https://releases.teamagentx.com/1.2.0/TeamAgentX-1.2.0-mac-arm64.dmg
VITE_DOWNLOAD_URL_MAC_X64=https://releases.teamagentx.com/1.2.0/TeamAgentX-1.2.0-mac-x64.dmg
VITE_DOWNLOAD_URL_WIN=https://releases.teamagentx.com/1.2.0/TeamAgentX-1.2.0-win.exe

# 移动端下载链接。当前官网隐藏了 iOS 下载入口，保留变量方便后续恢复。
VITE_DOWNLOAD_URL_IOS=https://apps.apple.com/app/teamagentx/id000000000
VITE_DOWNLOAD_URL_ANDROID=https://releases.teamagentx.com/1.2.0/TeamAgentX-1.2.0.apk

# 更新说明，写入 update.json。generate-update-json.mjs 也兼容 VITE_UPDATE_NOTES；
# Docker 入口脚本使用 VITE_APP_VERSION_NOTE。
VITE_APP_VERSION_NOTE=
# VITE_UPDATE_NOTES=

# 官网后端下载解析/上报服务地址。
#
# 浏览器始终访问同源的 /website-server/*。本地开发时由 Vite proxy 转发到
# WEBSITE_SERVER_PROXY_TARGET；Docker/nginx 部署时由 nginx 在运行时转发到同名变量。
#
# 本地开发：
WEBSITE_SERVER_PROXY_TARGET=http://127.0.0.1:3207

# Docker / 云上部署：
# WEBSITE_SERVER_PROXY_TARGET=http://website-server:3207

# ===== TeamAgentX Docker 部署环境变量 =====
# 复制为 .env 后按需修改：cp .env.docker.example .env

# 对外端口（宿主机）。纯内网 HTTP 直连时访问 http://<服务器IP>:${HOST_PORT}
HOST_PORT=3001

# JWT 密钥（强烈建议显式设置）：openssl rand -hex 32
# 留空则容器内自动生成并持久化到数据卷 /data/.jwt-secret（单实例可用）
JWT_SECRET=

# 单账号：用环境变量预置账号口令。启动即建好账号，防止他人在网络上抢先注册占用。
# 账号不存在则创建；与下方不一致则以此为准更新（改后重启即生效）。AUTH_PASSWORD 必填。
AUTH_USERNAME=admin
AUTH_PASSWORD=

# CORS allow-origin：默认 '*'（同源单容器本不依赖 CORS）。
# 公网部署建议收紧为具体来源，多个用逗号分隔，例如：
#   CORS_ORIGIN=https://team.example.com
CORS_ORIGIN=*

# ----- 仅启用 HTTPS 反代（--profile tls）时相关 -----
TLS_HTTP_PORT=80
TLS_HTTPS_PORT=443

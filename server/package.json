{
  "name": "server",
  "version": "1.0.0",
  "description": "Fastify server",
  "type": "module",
  "scripts": {
    "prestart": "prisma migrate deploy",
    "start": "tsx src/index.ts",
    "predev": "prisma migrate deploy",
    "dev": "tsx watch src/index.ts",
    "db:migrate": "prisma migrate dev",
    "prebuild:electron": "node scripts/pre-build-check.cjs",
    "db:generate": "prisma generate",
    "sync:prisma:prod": "node scripts/sync-prisma-client.cjs",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "build": "tsc && node scripts/copy-assets.cjs",
    "electron:entry": "tsc src/electron-entry.ts --outDir dist --moduleResolution node --module NodeNext --target ES2022 --esModuleInterop",
    "verify:electron-deps": "node scripts/verify-electron-deps.cjs",
    "test": "node --import tsx --import ./src/__tests__/test-bootstrap.ts --test --experimental-test-coverage src/**/*.test.ts",
    "test:watch": "node --import tsx --import ./src/__tests__/test-bootstrap.ts --test --watch src/**/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.2",
    "@anthropic-ai/claude-agent-sdk": "^0.2.121",
    "@anthropic-ai/sdk": "^0.95.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@larksuiteoapi/node-sdk": "^1.63.1",
    "@libsql/client": "^0.17.2",
    "@libsql/core": "^0.17.2",
    "@libsql/hrana-client": "^0.10.0",
    "@libsql/isomorphic-ws": "^0.1.5",
    "@neon-rs/load": "^0.2.6",
    "@openai/codex-sdk": "^0.128.0",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "acpx": "^0.5.3",
    "bcryptjs": "^3.0.3",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "cross-fetch": "^4.1.0",
    "detect-libc": "^2.1.2",
    "dingtalk-stream": "2.1.6-beta.1",
    "fastify": "^5.8.2",
    "fastify-type-provider-zod": "^6.1.0",
    "fflate": "^0.8.2",
    "js-base64": "^3.7.8",
    "jsonwebtoken": "^9.0.3",
    "libsql": "^0.5.28",
    "node-fetch": "^3.3.2",
    "openai": "^6.37.0",
    "promise-limit": "^2.7.0",
    "skillflag": "^0.1.4",
    "socket.io": "^4.8.3",
    "tree-kill": "^1.2.2",
    "unist-util-visit": "^5.1.0",
    "uuid": "^13.0.0",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^24.0.0",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  }
}

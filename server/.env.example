# ===== 服务端环境变量示例 =====
# 复制为 .env 后按需修改。所有 LLM 凭证主要存储在数据库 LlmProvider 表中，不在此配置。

# 运行环境：development | production
# 生产环境必须显式设置 JWT_SECRET，否则服务会拒绝启动。
NODE_ENV=development

# ----- HTTP 服务 -----
PORT=3001
SERVER_HOST=0.0.0.0

# ----- 数据库 -----
# SQLite 文件路径或 libsql 连接串。桌面版由 Electron 注入 userData 下的数据库路径。
DATABASE_URL=file:./dev.db

# ----- 鉴权 -----
# 留空时服务会在数据目录自动生成并持久化随机密钥（.jwt-secret）。
# 生产 / 多实例部署建议显式设置足够随机的长字符串（例如 openssl rand -hex 32）以便集中管理与共享。
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ----- Agent 记忆与历史 -----
AGENT_HISTORY_THRESHOLD=20
AGENT_MEMORY_RECENT_MESSAGES=10
AGENT_MEMORY_COMPACT_MESSAGES=40
AGENT_MEMORY_SUMMARY_TARGET_TOKENS=2000

# ----- 群调度助手 LLM 超时 -----
# 单次群调度 LLM 决策调用超时（毫秒）；设为 0 可禁用本地超时。
AGENT_COORDINATOR_LLM_TIMEOUT_MS=120000

# ----- 工具与技能目录 -----
# 工具目录（留空使用默认）。
TOOLS_DIR=
# 覆盖模板包技能的共享目录，默认 ~/.teamagentx/skills。
TEAMAGENTX_SHARED_SKILLS_DIR=

# ----- Bridge（可选）-----
BRIDGE_ENCRYPTION_KEY=
BRIDGE_REQUIRE_SIGNATURE=false

# ----- 语音合成（可选）-----
EDGE_TTS_BINARY=edge-tts
EDGE_TTS_DEFAULT_VOICE=zh-CN-XiaoxiaoNeural

# ----- OpenClaw ACP（可选）-----
# 也可由 start.sh 从 ~/.openclaw/openclaw.json 自动加载。
OPENCLAW_GATEWAY_TOKEN=

# ===== 服务端环境变量示例 =====
# 复制为 .env 后按需修改。所有 LLM 凭证主要存储在数据库 LlmProvider 表中，不在此配置。

# 运行环境：development | production
# 生产环境必须显式设置 JWT_SECRET，否则服务会拒绝启动。
NODE_ENV=development

# ----- HTTP 服务 -----
PORT=3001
SERVER_HOST=0.0.0.0
# CORS allow-origin：留空或 '*' 为通配（同源单容器本不依赖 CORS）；
# 公网部署可设为具体来源收紧，多个用逗号分隔，例如 https://team.example.com
CORS_ORIGIN=

# ----- 前端 SPA 托管（单容器 / 独立服务端部署）-----
# 指向前端构建产物目录（apps/web/dist）。留空则自动探测；探测不到则不托管前端
# （开发模式由 Vite 独立 serve，保持原行为）。Docker 镜像内已设为 /app/apps/web/dist。
WEB_DIST_DIR=

# ----- 数据库 -----
# SQLite 文件路径或 libsql 连接串。桌面版由 Electron 注入 userData 下的数据库路径。
DATABASE_URL=file:./dev.db

# ----- 文件与账号路径（独立部署/Docker 持久化用）-----
# 上传根目录（图片/音频），留空默认 <cwd>/uploads。
UPLOADS_DIR=
# 单账号本地用户文件路径，留空默认 ~/.teamagentx/user.json。
# Docker 部署应指向数据卷（如 /data/user.json）以持久化账号。
TEAMAGENTX_USER_FILE=

# ----- 环境变量预置单账号（独立部署/Docker，防止他人抢注）-----
# 同时设置时：账号不存在则创建；与现有不一致则以此为准更新（改后重启即生效）。
# 两者缺一则不生效，保持原有注册流程。
AUTH_USERNAME=
AUTH_PASSWORD=

# ----- 鉴权 -----
# 留空时服务会在数据目录自动生成并持久化随机密钥（.jwt-secret）。
# 生产 / 多实例部署建议显式设置足够随机的长字符串（例如 openssl rand -hex 32）以便集中管理与共享。
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ----- Agent 记忆与历史 -----
AGENT_HISTORY_THRESHOLD=20
AGENT_MEMORY_RECENT_MESSAGES=10
AGENT_MEMORY_COMPACT_MESSAGES=40
AGENT_MEMORY_SUMMARY_TARGET_TOKENS=2000

# ----- 群调度助手 LLM 超时与重试 -----
# 单次群调度 LLM 决策调用超时（毫秒）；设为 0 可禁用本地超时。
AGENT_COORDINATOR_LLM_TIMEOUT_MS=120000
# 超时后的重试次数；1 表示最多调用 2 次。
AGENT_COORDINATOR_LLM_RETRY_COUNT=1
AGENT_COORDINATOR_LLM_RETRY_DELAY_MS=1000

# ----- 工具与技能目录 -----
# 工具目录（留空使用默认）。
TOOLS_DIR=
# 覆盖模板包技能的共享目录，默认 ~/.teamagentx/skills。
TEAMAGENTX_SHARED_SKILLS_DIR=

# ----- Bridge（可选）-----
BRIDGE_ENCRYPTION_KEY=
BRIDGE_REQUIRE_SIGNATURE=false

# ----- 语音合成（可选）-----
EDGE_TTS_BINARY=edge-tts
EDGE_TTS_DEFAULT_VOICE=zh-CN-XiaoxiaoNeural

# ----- OpenClaw ACP（可选）-----
# 也可由 start.sh 从 ~/.openclaw/openclaw.json 自动加载。
OPENCLAW_GATEWAY_TOKEN=
